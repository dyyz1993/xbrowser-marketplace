# ===========================================
# Authentication
# ===========================================
AUTH_SECRET_KEY=           # Required: Secret key for JWT signing (NO default in production)
ENABLE_DEV_TOKENS=         # Set to 'true' to enable dev backdoor tokens (NEVER in production)
FILE_SECRET_KEY=           # Required: Secret key for file storage signed URLs

# ===========================================
# CORS
# ===========================================
CORS_ORIGIN=               # Comma-separated allowed origins (production only)

# ===========================================
# Server
# ===========================================
PORT=3010                  # Server port
NODE_ENV=development       # Environment: development | test | production

# ===========================================
# Database Configuration
# ===========================================
# Supported drivers: sqlite, mysql, d1
DB_DRIVER=sqlite

# ===========================================
# SQLite Configuration (Local Development)
# ===========================================
SQLITE_PATH=./data/app.db
DB_PATH=./data/app.db      # SQLite database path

# ===========================================
# MySQL Configuration (Production Server)
# ===========================================
# Uncomment and configure when using MySQL
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your_password
# MYSQL_DATABASE=biomimic_app

# ===========================================
# Cloudflare D1 Configuration
# ===========================================
# D1 is configured via wrangler.toml, not env vars
# The binding is automatically injected by Cloudflare Workers

# ===========================================
# Application Configuration
# ===========================================
# API Documentation (set to false in production)
ENABLE_DOCS=true

# Mock Mode (development)
VITE_USE_MOCK_SERVER=true

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW=60000    # Rate limit window in ms
RATE_LIMIT_MAX=100         # Max requests per window
